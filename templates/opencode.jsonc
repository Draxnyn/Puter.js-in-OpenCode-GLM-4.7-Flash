{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": ["puter"],
  "model": "puter/glm-4.7-flash",
  "agent": {
    "build": {
      "model": "puter/glm-4.7-flash",
      "prompt": "You are the master agent and always use GLM-4.7 Flash. Delegate parallel work only to puter-worker-1 through puter-worker-7. Their model is selected with /subagent. Never start more than seven subagents for one task; wait for them and consolidate their results.",
      "permission": {
        "task": {
          "*": "deny",
          "puter-worker-1": "allow",
          "puter-worker-2": "allow",
          "puter-worker-3": "allow",
          "puter-worker-4": "allow",
          "puter-worker-5": "allow",
          "puter-worker-6": "allow",
          "puter-worker-7": "allow"
        }
      }
    },
    "puter-worker-1": {
      "description": "Implementation and investigation subagent using the model selected with /subagent.",
      "mode": "subagent",
      "model": "puter/subagent",
      "steps": 12,
      "permission": { "task": "deny" }
    },
    "puter-worker-2": {
      "description": "Implementation and investigation subagent using the model selected with /subagent.",
      "mode": "subagent",
      "model": "puter/subagent",
      "steps": 12,
      "permission": { "task": "deny" }
    },
    "puter-worker-3": {
      "description": "Implementation and investigation subagent using the model selected with /subagent.",
      "mode": "subagent",
      "model": "puter/subagent",
      "steps": 12,
      "permission": { "task": "deny" }
    },
    "puter-worker-4": {
      "description": "Implementation and investigation subagent using the model selected with /subagent.",
      "mode": "subagent",
      "model": "puter/subagent",
      "steps": 12,
      "permission": { "task": "deny" }
    },
    "puter-worker-5": {
      "description": "Implementation and investigation subagent using the model selected with /subagent.",
      "mode": "subagent",
      "model": "puter/subagent",
      "steps": 12,
      "permission": { "task": "deny" }
    },
    "puter-worker-6": {
      "description": "Implementation and investigation subagent using the model selected with /subagent.",
      "mode": "subagent",
      "model": "puter/subagent",
      "steps": 12,
      "permission": { "task": "deny" }
    },
    "puter-worker-7": {
      "description": "Implementation and investigation subagent using the model selected with /subagent.",
      "mode": "subagent",
      "model": "puter/subagent",
      "steps": 12,
      "permission": { "task": "deny" }
    }
  },
  "provider": {
    "puter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Puter free models",
      "options": {
        "baseURL": "http://127.0.0.1:8765/v1",
        "apiKey": "{env:PUTER_BRIDGE_TOKEN}"
      },
      "models": {
        "glm-4.7-flash": {
          "name": "GLM-4.7 Flash via Puter",
          "limit": { "context": 131072, "output": 8192 }
        },
        "nemotron-nano-9b-v2-free": {
          "name": "NVIDIA Nemotron Nano 9B V2 via Puter",
          "limit": { "context": 131072, "output": 8192 }
        },
        "cobuddy-free": {
          "name": "Baidu Qianfan CoBuddy via Puter",
          "limit": { "context": 131072, "output": 8192 }
        },
        "subagent": {
          "name": "Subagent model selected with /subagent",
          "limit": { "context": 131072, "output": 8192 }
        }
      }
    }
  }
}
